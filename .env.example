NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=

# 46elks SMS
ELKS_API_USERNAME=
ELKS_API_PASSWORD=
ELKS_WEBHOOK_SECRET=        # Required in production. In dev, can be omitted (webhook accepts all requests).
ELKS_DRY_RUN=false          # Set to true to skip sending real SMS (46elks dryrun mode)
